,\n          ),\n      }))\n    },\n    splitPhrase(phrase) {\n      return phrase\n        .replace(/^\\s+|\\s+$/g, '&nbsp;')\n        .replace('***', '___*___')\n        .split('___')\n        .filter(Boolean)\n    },\n  },\n}\n"],"mappings":";;;;AAAA,eAAe;EACbA,IAAI,EAAEA,CAAA,MAAO;IACXC,GAAG,EAAEC,IAAI,CAACC,KAAK,CAACD,IAAI,CAACE,MAAM,CAAC,CAAC,GAAG,EAAE,IAAI,EAAE;EAC1C,CAAC,CAAC;EACFC,OAAO,EAAE;IACPC,YAAYA,CAACC,UAAU,EAAEC,WAAW,GAAG,KAAK,EAAE;MAC5C,IAAI,CAACD,UAAU,CAACE,OAAO,EAAE,OAAO,EAAE;MAClC,OAAOF,UAAU,CAACE,OAAO,CAACC,GAAG,CAAC,CAACC,IAAI,EAAEC,GAAG,MAAM;QAC5C,GAAGD,IAAI;QACPE,EAAE,EAAE,IAAI,CAACZ,GAAG,GAAGW,GAAG,GAAG,CAAC;QACtBE,QAAQ,EAAEN,WAAW,GAAG,IAAI,CAACO,WAAW,CAACJ,IAAI,CAACG,QAAQ,CAAC,GAAGH,IAAI,CAACG,QAAQ;QACvEE,QAAQ,EAAER,WAAW,GAAG,IAAI,CAACO,WAAW,CAACJ,IAAI,CAACK,QAAQ,CAAC,GAAGL,IAAI,CAACK,QAAQ;QACvEC,SAAS,EACPV,UAAU,CAACW,UAAU,IACrBX,UAAU,CAACW,UAAU,CAACC,IAAI,CACxBF,SAAS,IAAIA,SAAS,CAACG,MAAM,KAAKT,IAAI,CAACM,SACzC;MACJ,CAAC,CAAC,CAAC;IACL,CAAC;IACDF,WAAWA,CAACM,MAAM,EAAE;MAClB,OAAOA,MAAM,CACVC,OAAO,CAAC,YAAY,EAAE,QAAQ,CAAC,CAC/BA,OAAO,CAAC,KAAK,EAAE,SAAS,CAAC,CACzBC,KAAK,CAAC,KAAK,CAAC,CACZC,MAAM,CAACC,OAAO,CAAC;IACpB;EACF;AACF,CAAC","ignoreList":[]}]}